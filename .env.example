# ── LLM Provider ──────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=

# Or OpenRouter (set both to use OpenRouter instead of OpenAI)
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Search (free tier at tavily.com) ──────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxx

# ── Optional ──────────────────────────────────────────────────────────────────
MODEL=gpt-4o-mini          # OpenRouter example: google/gemini-2.0-flash-001
MAX_STEPS=5                # Lower = fewer LLM calls per request
MAX_TOKENS=1024            # Lower = cheaper per response (OpenRouter max 6477)
PORT=3000
